{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "installCommand": "npm install --legacy-peer-deps",
    "rewrites": [
        { "source": "/.well-known/assetlinks.json", "destination": "/api/well-known/assetlinks.json" },
        { "source": "/(.*)", "destination": "/index.html" }
    ]
}
